# LLM
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

# Vector DB
VECTOR_DB_BACKEND=chroma   # chroma | weaviate | pinecone
CHROMA_PERSIST_DIR=./data/chroma_db
WEAVIATE_URL=http://localhost:8080
PINECONE_API_KEY=
PINECONE_ENV=

# Graph DB
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# App
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# Auth / role gating
JWT_SECRET=change-me-in-production
ADMIN_API_KEY=admin-dev-key

# Data paths
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
CURATED_DATA_DIR=./data/curated

# Audit
AUDIT_DB_PATH=./data/audit.db
AUDIT_IP_SALT=change-this-to-a-random-secret-in-production

# Prescriber frontend static directory
FRONTEND_DIR=./apps/frontend

# PubMed
PUBMED_EMAIL=your@email.com
PUBMED_API_KEY=

# YouTube
YOUTUBE_API_KEY=

# Feature flags
ENABLE_GRAPH_RETRIEVAL=false
ENABLE_RECONSTITUTION_GUIDANCE=false
